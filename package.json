{
  "name": "agentic-flow",
  "displayName": "Agentic Flow",
  "description": "Multi-model AI development pipeline orchestrator. Spec → Plan → Build → Review → Test → Security → Done.",
  "version": "1.0.0",
  "publisher": "agentic-flow",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "icon": "media/icon.png",
  "keywords": [
    "ai",
    "agent",
    "claude",
    "openai",
    "codex",
    "pipeline",
    "workflow"
  ],
  "activationEvents": [
    "onView:agenticFlow.panel",
    "onCommand:agenticFlow.open",
    "onCommand:agenticFlow.refreshModels",
    "onCommand:agenticFlow.initWorkspace",
    "onCommand:agenticFlow.openSettings",
    "onCommand:agenticFlow.openWorkspaceConfig",
    "onCommand:agenticFlow.openRuntimeEnv",
    "onCommand:agenticFlow.revealSkillsFolder",
    "onCommand:agenticFlow.setProviderApiKey",
    "onCommand:agenticFlow.clearProviderApiKey"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agenticFlow",
          "title": "Agentic Flow",
          "icon": "media/icon-activitybar.svg"
        }
      ]
    },
    "views": {
      "agenticFlow": [
        {
          "type": "webview",
          "id": "agenticFlow.panel",
          "name": "Agentic Flow"
        }
      ]
    },
    "commands": [
      {
        "command": "agenticFlow.open",
        "title": "Agentic Flow: Open Pipeline",
        "icon": "$(rocket)"
      },
      {
        "command": "agenticFlow.refreshModels",
        "title": "Agentic Flow: Refresh Models & CLIs"
      },
      {
        "command": "agenticFlow.initWorkspace",
        "title": "Agentic Flow: Init Workspace"
      },
      {
        "command": "agenticFlow.openSettings",
        "title": "Agentic Flow: Open VS Code Settings"
      },
      {
        "command": "agenticFlow.openWorkspaceConfig",
        "title": "Agentic Flow: Open Workspace Config"
      },
      {
        "command": "agenticFlow.openRuntimeEnv",
        "title": "Agentic Flow: Open Runtime Env"
      },
      {
        "command": "agenticFlow.revealSkillsFolder",
        "title": "Agentic Flow: Reveal Skills Folder"
      },
      {
        "command": "agenticFlow.setProviderApiKey",
        "title": "Agentic Flow: Store Provider API Key"
      },
      {
        "command": "agenticFlow.clearProviderApiKey",
        "title": "Agentic Flow: Clear Provider API Key"
      },
      {
        "command": "agenticFlow.openDocs",
        "title": "Agentic Flow: Open Documentation"
      },
      {
        "command": "agenticFlow.generateRepoMd",
        "title": "Agentic Flow: Generate REPO.md"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "agenticFlow.open"
        },
        {
          "command": "agenticFlow.refreshModels"
        },
        {
          "command": "agenticFlow.initWorkspace"
        },
        {
          "command": "agenticFlow.openSettings"
        },
        {
          "command": "agenticFlow.openWorkspaceConfig"
        },
        {
          "command": "agenticFlow.openRuntimeEnv"
        },
        {
          "command": "agenticFlow.revealSkillsFolder"
        },
        {
          "command": "agenticFlow.setProviderApiKey"
        },
        {
          "command": "agenticFlow.clearProviderApiKey"
        },
        {
          "command": "agenticFlow.openDocs"
        },
        {
          "command": "agenticFlow.generateRepoMd"
        }
      ]
    },
    "keybindings": [
      {
        "command": "agenticFlow.open",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Agentic Flow",
      "properties": {
        "agenticFlow.autoDetectClis": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect installed AI CLIs on startup"
        },
        "agenticFlow.extraCliPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directories to search for CLI binaries"
        },
        "agenticFlow.workspaceStorageDir": {
          "type": "string",
          "default": ".agentic-flow",
          "markdownDescription": "Workspace-local storage directory used for `config.json`, `runtime.env`, session files and skills. Use [Open config.json](command:agenticFlow.openWorkspaceConfig), [Open runtime.env](command:agenticFlow.openRuntimeEnv), [Reveal skills folder](command:agenticFlow.revealSkillsFolder), or [open all Agentic Flow settings](command:agenticFlow.openSettings)."
        },
        "agenticFlow.apiProviders": {
          "type": "object",
          "default": {
            "openai": {
              "enabled": false,
              "baseUrl": "https://api.openai.com/v1",
              "apiKey": "",
              "modelAllowList": []
            },
            "anthropic": {
              "enabled": false,
              "baseUrl": "https://api.anthropic.com/v1",
              "apiKey": "",
              "modelAllowList": []
            },
            "xai": {
              "enabled": false,
              "baseUrl": "https://api.x.ai/v1",
              "apiKey": "",
              "modelAllowList": []
            },
            "openrouter": {
              "enabled": false,
              "baseUrl": "https://openrouter.ai/api/v1",
              "apiKey": "",
              "modelAllowList": []
            },
            "ollama": {
              "enabled": false,
              "baseUrl": "http://localhost:11434/v1",
              "apiKey": "",
              "modelAllowList": []
            }
          },
          "markdownDescription": "API providers exposed alongside local CLIs. Keep local CLIs as the default path, then add providers here when you want API-backed models to appear in selectors too. For best security, store keys with [Agentic Flow: Store Provider API Key](command:agenticFlow.setProviderApiKey). Compatibility fallback: keys can still come from this setting or from `.agentic-flow/runtime.env` (`OPENAI_API_KEY`, `ANTHROPIC_API_KEY`, `XAI_API_KEY`, `OPENROUTER_API_KEY`). Prefer also setting `modelAllowList` when you want to limit discovery.",
          "additionalProperties": false,
          "properties": {
            "openai": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "baseUrl": {
                  "type": "string",
                  "default": "https://api.openai.com/v1"
                },
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "format": "password"
                },
                "modelAllowList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            },
            "anthropic": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "baseUrl": {
                  "type": "string",
                  "default": "https://api.anthropic.com/v1"
                },
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "format": "password"
                },
                "modelAllowList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            },
            "xai": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "baseUrl": {
                  "type": "string",
                  "default": "https://api.x.ai/v1"
                },
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "format": "password"
                },
                "modelAllowList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            },
            "openrouter": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "baseUrl": {
                  "type": "string",
                  "default": "https://openrouter.ai/api/v1"
                },
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "format": "password"
                },
                "modelAllowList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            },
            "ollama": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "baseUrl": {
                  "type": "string",
                  "default": "http://localhost:11434/v1"
                },
                "apiKey": {
                  "type": "string",
                  "default": "",
                  "format": "password"
                },
                "modelAllowList": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "default": []
                }
              }
            }
          }
        },
        "agenticFlow.runProfile": {
          "type": "string",
          "enum": [
            "lite",
            "standard",
            "full",
            "evolutive",
            "hotfix",
            "custom"
          ],
          "default": "standard",
          "scope": "resource",
          "description": "Default run profile for this workspace."
        },
        "agenticFlow.defaultModel": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Fallback model used when a step has no explicit model and no model-router match."
        },
        "agenticFlow.summaryMaxTokens": {
          "type": "number",
          "default": 250,
          "minimum": 50,
          "scope": "resource",
          "description": "Token budget for compact per-step summaries injected into downstream steps."
        },
        "agenticFlow.contextMaxTokens": {
          "type": "number",
          "default": 1400,
          "minimum": 100,
          "scope": "resource",
          "description": "Total token budget for previous-step context injected into each step."
        },
        "agenticFlow.modelRouter": {
          "type": "object",
          "scope": "resource",
          "default": {},
          "description": "Map step categories to model IDs. Used when a step has no explicit model.",
          "additionalProperties": false,
          "properties": {
            "planning": {
              "type": "string",
              "default": ""
            },
            "generation": {
              "type": "string",
              "default": ""
            },
            "review": {
              "type": "string",
              "default": ""
            },
            "verification": {
              "type": "string",
              "default": ""
            },
            "reporting": {
              "type": "string",
              "default": ""
            }
          }
        },
        "agenticFlow.gitContext": {
          "type": "object",
          "scope": "resource",
          "default": {
            "enabled": true,
            "maxTokens": 500,
            "recentCommits": 5
          },
          "description": "Git diff/log context injected into step prompts.",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "maxTokens": {
              "type": "number",
              "default": 500,
              "minimum": 100
            },
            "recentCommits": {
              "type": "number",
              "default": 5,
              "minimum": 1,
              "maximum": 20
            }
          }
        },
        "agenticFlow.runtime": {
          "type": "object",
          "scope": "resource",
          "default": {
            "env": {},
            "envFiles": [
              ".agentic-flow/runtime.env"
            ],
            "customClis": [],
            "customModels": []
          },
          "description": "Runtime environment files, inline env vars, custom CLIs and custom models.",
          "additionalProperties": false,
          "properties": {
            "env": {
              "type": "object",
              "default": {},
              "additionalProperties": {
                "type": "string"
              }
            },
            "envFiles": {
              "type": "array",
              "default": [
                ".agentic-flow/runtime.env"
              ],
              "items": {
                "type": "string"
              }
            },
            "customClis": {
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  }
                }
              }
            },
            "customModels": {
              "type": "array",
              "default": [],
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "label": {
                    "type": "string"
                  },
                  "cliId": {
                    "type": "string"
                  },
                  "modelName": {
                    "type": "string"
                  },
                  "contextWindow": {
                    "type": "number"
                  },
                  "launchArgs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": []
                  },
                  "env": {
                    "type": "object",
                    "default": {},
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "description": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "agenticFlow.steps": {
          "type": "array",
          "scope": "resource",
          "default": [],
          "description": "Advanced: override the default pipeline steps for this workspace.",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "enabled": {
                "type": "boolean"
              },
              "model": {
                "type": "string"
              },
              "executor": {
                "type": "string",
                "enum": [
                  "model",
                  "hard-check"
                ]
              },
              "cli": {
                "type": "string"
              },
              "skill": {
                "type": "string"
              },
              "contextMode": {
                "type": "string",
                "enum": [
                  "summary",
                  "full",
                  "none"
                ]
              },
              "contextStepIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "contextFiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "runCondition": {
                "type": "string",
                "enum": [
                  "always",
                  "ifIssues"
                ]
              },
              "goal": {
                "type": "string"
              },
              "category": {
                "type": "string",
                "enum": [
                  "planning",
                  "generation",
                  "review",
                  "verification",
                  "reporting"
                ]
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "package:ci": "vsce package --allow-missing-repository --out dist/agentic-flow.vsix",
    "dev:host": "code . --new-window --extensionDevelopmentPath=. --user-data-dir ./.vscode-test/user-data --extensions-dir ./.vscode-test/extensions",
    "dev:host:insiders": "code-insiders . --new-window --extensionDevelopmentPath=. --user-data-dir ./.vscode-test/user-data --extensions-dir ./.vscode-test/extensions",
    "dev:host:workspace": "mkdir -p ./.vscode-test/workspace && code ./.vscode-test/workspace --new-window --extensionDevelopmentPath=. --user-data-dir ./.vscode-test/user-data --extensions-dir ./.vscode-test/extensions"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
